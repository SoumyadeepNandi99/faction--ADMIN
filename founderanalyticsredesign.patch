+"use client";
+
+import { Layers, BookOpen } from "lucide-react";
+import { useBankExamDistribution, useDifficultyDistribution } from "@/components/analytics/data";
+import { KpiCard, Card, Section, EmptyState, ChartSkeleton, PageHeading, UnavailablePill, LazyMount } from "@/components/analytics/primitives";
+import { HBarList, DonutChart } from "@/components/analytics/charts";
+import { formatExamType } from "@/lib/exam-types";
+
+export default function TopicsPage() {
+    const { dist: difficulty, loading: diffLoading } = useDifficultyDistribution();
+    const { dist: byExam, loading: examLoading } = useBankExamDistribution();
+
+    const totalBank = difficulty.reduce((a, b) => a + b.count, 0);
+
+    return (
+        <>
+            <PageHeading title="Topic Analytics" description="Question-bank composition. Per-topic solve/accuracy needs data the API doesn't expose." />
+
+            <div className="glass-card p-4 flex items-start gap-3">
+                <Layers className="h-5 w-5 text-brand-500 shrink-0 mt-0.5" />
+                <p className="text-sm text-muted-foreground">
+                    The API exposes the <span className="text-foreground font-medium">question bank</span> (by difficulty and exam),
+                    but per-attempt solves are user-scoped — so <span className="text-foreground font-medium">most-solved</span>,
+                    <span className="text-foreground font-medium"> topic accuracy</span> and topic heatmaps aren&apos;t derivable
+                    admin-wide. What the bank supports is shown below; the rest is marked honestly.
+                </p>
+            </div>
+
+            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
+                <KpiCard label="Bank Size" value={diffLoading ? "…" : totalBank} icon={<BookOpen className="h-5 w-5" />} sub="total questions" unavailable={!diffLoading && totalBank === 0} unavailableReason="Question bank returned no rows." />
+                <KpiCard label="Easy" value={diffLoading ? "…" : (difficulty.find(d => d.label === "Easy")?.count ?? 0)} icon={<Layers className="h-5 w-5" />} accent="blue" />
+                <KpiCard label="Medium" value={diffLoading ? "…" : (difficulty.find(d => d.label === "Medium")?.count ?? 0)} icon={<Layers className="h-5 w-5" />} accent="purple" />
+                <KpiCard label="Hard" value={diffLoading ? "…" : (difficulty.find(d => d.label === "Hard")?.count ?? 0)} icon={<Layers className="h-5 w-5" />} accent="pink" />
+            </div>
+
+            <LazyMount>
+                <Section title="Question Bank Composition" description="What the practice pool is made of">
+                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
+                        <Card title="By Difficulty">
+                            {diffLoading ? <ChartSkeleton /> : difficulty.some(d => d.count > 0) ? <HBarList data={difficulty} colorByIndex /> : <EmptyState message="No question-bank data." />}
+                        </Card>
+                        <Card title="By Exam Track">
+                            {examLoading ? <ChartSkeleton /> : byExam.length ? <DonutChart data={byExam.map(b => ({ label: formatExamType(b.label), count: b.count }))} /> : <EmptyState message="No question-bank data." />}
+                        </Card>
+                    </div>
+                </Section>
+            </LazyMount>
+
+            <LazyMount>
+                <Section title="Topic Performance" description="Not derivable — per-topic solves & accuracy are user-scoped">
+                    <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
+                        {[
+                            { t: "Most / Least Solved Topics", r: "Per-topic solve counts aren't exposed admin-wide (attempts are scoped to each user)." },
+                            { t: "Strongest / Weakest Topics", r: "Requires per-topic accuracy across students, which no endpoint returns." },
+                            { t: "Topic Heatmap & Accuracy", r: "No admin-wide topic-level performance feed exists to build a heatmap from." },
+                        ].map(x => (
+                            <Card key={x.t} title={x.t}><UnavailablePill reason={x.r} /></Card>
+                        ))}
+                    </div>
+                </Section>
+            </LazyMount>
+        </>
+    );
+}
