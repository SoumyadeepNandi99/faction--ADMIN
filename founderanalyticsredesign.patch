+// ---------------------------------------------------------------------------
+
+export interface QotdSchedule {
+    id: string | null;
+    question_ids: string[];
+}
+
+/** The POTD scheduled for one day/class/exam (null-ish when nothing is set). */
+export async function fetchQotdSchedule(scheduled_date: string, class_id: string, exam_type: string): Promise<QotdSchedule | null> {
+    try {
+        const { data } = await apiClient.get("/api/v1/qotd/schedule", {
+            params: { scheduled_date, class_id, exam_type },
+        });
+        return { id: (data?.id as string) ?? null, question_ids: (data?.question_ids as string[]) ?? [] };
+    } catch {
