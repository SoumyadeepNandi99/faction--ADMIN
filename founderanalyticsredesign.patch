+"use client";
+
+import { useMemo, useState } from "react";
+import { Swords, CheckCircle2, Divide, Trophy } from "lucide-react";
+import { bucketize } from "@/lib/api/analytics";
+import { useArena, useBankExamDistribution, useDifficultyDistribution } from "@/components/analytics/data";
+import { RangeFilter, defaultRange, rangeLabel, rangeToTimeFilter, type Range } from "@/components/analytics/range";
+import { KpiCard, Card, Section, EmptyState, ChartSkeleton, PageHeading, UnavailablePill, LazyMount, DataTable, RankBadge, NameCell, type Column } from "@/components/analytics/primitives";
+import { HBarList, DonutChart } from "@/components/analytics/charts";
+import { formatExamType } from "@/lib/exam-types";
+
+export default function ProblemSolvingPage() {
+    const [range, setRange] = useState<Range>(defaultRange);
+    const tf = rangeToTimeFilter(range);
+    const { rows, loading } = useArena(tf);
+    const { dist: difficulty, loading: diffLoading } = useDifficultyDistribution();
+    const { dist: byExam, loading: examLoading } = useBankExamDistribution();
+
+    const solved = rows.map(r => r.questions_solved);
+    const totalSolved = solved.reduce((a, b) => a + b, 0);
+    const solvers = rows.length;
+
+    const dist = useMemo(
+        () =>
+            bucketize(solved, [
+                { label: "1–10", min: 1, max: 10 },
+                { label: "11–50", min: 11, max: 50 },
+                { label: "51–100", min: 51, max: 100 },
+                { label: "101–250", min: 101, max: 250 },
+                { label: "251–500", min: 251, max: 500 },
+                { label: "500+", min: 501 },
+            ]),
+        [solved],
