+++ b/src/components/analytics/range.tsx
@@ -0,0 +1,102 @@
+"use client";
+
+/**
+ * Per-section time-range filter (Today / Last 7 Days / Last 30 Days / Custom).
+ * Each analytics page owns its own Range state, so changing the window on one
+ * page never affects another. Dates are IST calendar days ("YYYY-MM-DD").
+ *
+ * NOTE on ranking windows: the arena/rating/streak endpoints only expose
+ * daily | weekly | all_time windows, so a *custom* range can't re-slice those.
+ * The range therefore fully drives user/registration time-series (derived from
+ * created_at) and selects the closest arena window for activity metrics; pages
+ * say so where the mapping is approximate.
+ */
+
+import { istTodayKey, shiftDateKey, type TimeFilter } from "@/lib/api/analytics";
+
+export type PresetKey = "today" | "7d" | "30d";
+export type RangeKey = PresetKey | "custom";
+
+export interface Range {
+    key: RangeKey;
+    from: string; // inclusive "YYYY-MM-DD"
+    to: string; // inclusive "YYYY-MM-DD"
+}
+
+const PRESETS: { key: PresetKey; label: string; days: number }[] = [
+    { key: "today", label: "Today", days: 1 },
+    { key: "7d", label: "Last 7 Days", days: 7 },
+    { key: "30d", label: "Last 30 Days", days: 30 },
+];
+
+/** Compute the [from, to] IST day window for a preset. */
+export function presetRange(key: PresetKey): Range {
+    const to = istTodayKey();
+    const days = PRESETS.find(p => p.key === key)?.days ?? 30;
+    return { key, from: shiftDateKey(to, -(days - 1)), to };
+}
+
+export function defaultRange(): Range {
+    return presetRange("30d");
+}
+
+export function rangeLabel(r: Range): string {
+    if (r.key === "custom") return `${r.from || "…"} → ${r.to || "…"}`;
+    return PRESETS.find(p => p.key === r.key)?.label ?? "Last 30 Days";
+}
+
+/** Best-effort mapping of a range to the arena/ranking window it approximates. */
+export function rangeToTimeFilter(r: Range): TimeFilter | undefined {
+    if (r.key === "today") return "daily";
+    if (r.key === "7d") return "weekly";
+    return undefined; // 30d / custom → all-time (no monthly window exists)
+}
+
+export function RangeFilter({ value, onChange }: { value: Range; onChange: (r: Range) => void }) {
+    return (
+        <div className="flex flex-wrap items-center gap-2">
+            <div className="inline-flex items-center rounded-xl bg-foreground/5 border border-(--card-border) p-1">
+                {PRESETS.map(p => (
+                    <button
+                        key={p.key}
+                        onClick={() => onChange(presetRange(p.key))}
+                        className={`px-3 py-1.5 text-xs font-semibold rounded-lg transition-all ${
+                            value.key === p.key
+                                ? "bg-brand-500 text-white shadow-sm"
+                                : "text-muted-foreground hover:text-foreground"
+                        }`}
+                    >
+                        {p.label}
+                    </button>
+                ))}
+                <button
+                    onClick={() => onChange({ ...value, key: "custom" })}
+                    className={`px-3 py-1.5 text-xs font-semibold rounded-lg transition-all ${
+                        value.key === "custom" ? "bg-brand-500 text-white shadow-sm" : "text-muted-foreground hover:text-foreground"
+                    }`}
+                >
+                    Custom
+                </button>
+            </div>
+            {value.key === "custom" && (
+                <div className="flex items-center gap-2">
+                    <input
+                        type="date"
+                        value={value.from}
+                        max={value.to || undefined}
+                        onChange={e => onChange({ ...value, key: "custom", from: e.target.value })}
+                        className="rounded-lg bg-foreground/5 border border-(--card-border) px-2.5 py-1.5 text-xs text-foreground focus:outline-none focus:ring-2 focus:ring-brand-500/30"
+                    />
+                    <span className="text-xs text-muted-foreground">to</span>
+                    <input
+                        type="date"
+                        value={value.to}
+                        min={value.from || undefined}
+                        onChange={e => onChange({ ...value, key: "custom", to: e.target.value })}
+                        className="rounded-lg bg-foreground/5 border border-(--card-border) px-2.5 py-1.5 text-xs text-foreground focus:outline-none focus:ring-2 focus:ring-brand-500/30"
+                    />
+                </div>
+            )}
+        </div>
+    );
+}
