@@ -0,0 +1,152 @@
+"use client";
+
+import { useMemo, useState } from "react";
+import useSWR from "swr";
+import { Swords, Flame, Star, TrendingUp, Award } from "lucide-react";
+import { fetchContestRanking } from "@/lib/api/analytics";
+import { useArena, useContests, useRating, useStreak } from "@/components/analytics/data";
+import { Card, EmptyState, ChartSkeleton, PageHeading, UnavailablePill, DataTable, RankBadge, NameCell, type Column } from "@/components/analytics/primitives";
+
+type Board = "practice" | "contest" | "consistent" | "rated" | "improved";
+
+const TABS: { key: Board; label: string; icon: React.ReactNode }[] = [
+    { key: "practice", label: "Practice", icon: <Swords className="h-4 w-4" /> },
+    { key: "contest", label: "Weekly Contest", icon: <Award className="h-4 w-4" /> },
+    { key: "consistent", label: "Most Consistent", icon: <Flame className="h-4 w-4" /> },
+    { key: "rated", label: "Highest Rated", icon: <Star className="h-4 w-4" /> },
+    { key: "improved", label: "Most Improved", icon: <TrendingUp className="h-4 w-4" /> },
+];
+
+export default function LeaderboardsPage() {
+    const [board, setBoard] = useState<Board>("practice");
+    const { rows: arena, loading: arenaLoading } = useArena(undefined);
+    const { rows: rating, loading: ratingLoading } = useRating();
+    const { rows: streak, loading: streakLoading } = useStreak();
+    const { contests } = useContests();
+
+    const latest = useMemo(
+        () => [...contests].filter(c => c.status === "finished").sort((a, b) => new Date(b.starts_at).getTime() - new Date(a.starts_at).getTime())[0] ?? null,
+        [contests],
+    );
+    const { data: contestRanking, isLoading: contestLoading } = useSWR(
+        latest ? `analytics:contest-ranking:${latest.id}` : null,
+        () => fetchContestRanking(latest!.id),
+        { revalidateOnFocus: false, dedupingInterval: 300_000 },
+    );
+
+    return (
+        <>
+            <PageHeading title="Leaderboards" description="Top students across every ranking dimension." />
+
+            <div className="flex items-center gap-2 overflow-x-auto pb-1">
+                {TABS.map(t => (
+                    <button
+                        key={t.key}
+                        onClick={() => setBoard(t.key)}
+                        className={`inline-flex items-center gap-2 whitespace-nowrap rounded-xl px-4 py-2 text-sm font-semibold transition-all ${
+                            board === t.key ? "bg-brand-500 text-white shadow-sm shadow-brand-500/20" : "glass-card text-muted-foreground hover:text-foreground"
+                        }`}
+                    >
+                        {t.icon}
+                        {t.label}
+                    </button>
+                ))}
+            </div>
+
+            <Card>
+                {board === "practice" && <PracticeBoard rows={arena} loading={arenaLoading} />}
+                {board === "rated" && <RatedBoard rows={rating} loading={ratingLoading} />}
+                {board === "consistent" && <ConsistentBoard rows={streak} loading={streakLoading} />}
+                {board === "contest" && <ContestBoard rows={contestRanking?.rows ?? []} loading={contestLoading} contestName={latest?.name} hasContest={Boolean(latest)} />}
+                {board === "improved" && <ImprovedBoard rows={contestRanking?.rows ?? []} loading={contestLoading} contestName={latest?.name} hasContest={Boolean(latest)} />}
+            </Card>
+        </>
+    );
+}
+
+function BoardHeader({ icon, title, subtitle }: { icon: React.ReactNode; title: string; subtitle: string }) {
+    return (
+        <div className="flex items-center gap-3 mb-4">
+            <div className="p-2 rounded-xl bg-brand-500/10 text-brand-500 border border-brand-500/20">{icon}</div>
+            <div>
+                <h3 className="font-semibold text-foreground">{title}</h3>
+                <p className="text-xs text-muted-foreground">{subtitle}</p>
+            </div>
+        </div>
+    );
+}
+
+function PracticeBoard({ rows, loading }: { rows: { user_name: string; questions_solved: number }[]; loading: boolean }) {
+    const cols: Column<(typeof rows)[number]>[] = [
+        { key: "rank", header: "#", render: (_r, i) => <RankBadge rank={i + 1} />, align: "center", className: "w-10" },
+        { key: "name", header: "Student", render: r => <NameCell name={r.user_name} /> },
+        { key: "solved", header: "Solved", render: r => <span className="font-bold tabular-nums">{(r.questions_solved ?? 0).toLocaleString()}</span>, align: "right" },
+    ];
+    return (
+        <>
+            <BoardHeader icon={<Swords className="h-5 w-5" />} title="Practice Leaderboard" subtitle="All-time problems solved in the arena" />
+            {loading ? <ChartSkeleton height={300} /> : rows.length ? <DataTable columns={cols} rows={rows} searchable searchKeys={r => r.user_name} searchPlaceholder="Search students…" pageSize={15} /> : <EmptyState message="Arena ranking returned no rows." />}
+        </>
+    );
+}
+
+function RatedBoard({ rows, loading }: { rows: { user_name: string; current_rating: number; max_rating: number; title: string }[]; loading: boolean }) {
+    const cols: Column<(typeof rows)[number]>[] = [
+        { key: "rank", header: "#", render: (_r, i) => <RankBadge rank={i + 1} />, align: "center", className: "w-10" },
+        { key: "name", header: "Student", render: r => <NameCell name={r.user_name} /> },
+        { key: "title", header: "Title", render: r => <span className="text-xs text-muted-foreground">{r.title || "—"}</span> },
+        { key: "peak", header: "Peak", render: r => <span className="text-muted-foreground tabular-nums">{(r.max_rating ?? 0).toLocaleString()}</span>, align: "right" },
+        { key: "rating", header: "Rating", render: r => <span className="font-bold tabular-nums">{(r.current_rating ?? 0).toLocaleString()}</span>, align: "right" },
+    ];
+    return (
+        <>
+            <BoardHeader icon={<Star className="h-5 w-5" />} title="Highest Rated" subtitle="Top competitive ratings" />
+            {loading ? <ChartSkeleton height={300} /> : rows.length ? <DataTable columns={cols} rows={rows} searchable searchKeys={r => r.user_name} searchPlaceholder="Search students…" pageSize={15} /> : <EmptyState message="Rating ranking returned no rows." />}
+        </>
+    );
+}
+
+function ConsistentBoard({ rows, loading }: { rows: { user_name: string; streak_count: number }[]; loading: boolean }) {
+    const cols: Column<(typeof rows)[number]>[] = [
+        { key: "rank", header: "#", render: (_r, i) => <RankBadge rank={i + 1} />, align: "center", className: "w-10" },
+        { key: "name", header: "Student", render: r => <NameCell name={r.user_name} /> },
+        { key: "streak", header: "Streak", render: r => <span className="font-bold tabular-nums">{(r.streak_count ?? 0).toLocaleString()} days</span>, align: "right" },
+    ];
+    return (
+        <>
+            <BoardHeader icon={<Flame className="h-5 w-5" />} title="Most Consistent" subtitle="Longest active study streaks" />
+            {loading ? <ChartSkeleton height={300} /> : rows.length ? <DataTable columns={cols} rows={rows} searchable searchKeys={r => r.user_name} searchPlaceholder="Search students…" pageSize={15} /> : <EmptyState message="Streak ranking returned no rows." />}
+        </>
+    );
+}
+
+function ContestBoard({ rows, loading, contestName, hasContest }: { rows: { user_name: string; score: number; rank: number; accuracy: number }[]; loading: boolean; contestName?: string; hasContest: boolean }) {
+    const cols: Column<(typeof rows)[number]>[] = [
+        { key: "rank", header: "#", render: r => <RankBadge rank={r.rank} />, align: "center", className: "w-10" },
+        { key: "name", header: "Student", render: r => <NameCell name={r.user_name} /> },
+        { key: "acc", header: "Accuracy", render: r => <span className="text-muted-foreground tabular-nums">{Math.round((r.accuracy || 0) * 100)}%</span>, align: "right" },
+        { key: "score", header: "Score", render: r => <span className="font-bold tabular-nums">{(r.score ?? 0).toLocaleString()}</span>, align: "right" },
+    ];
+    return (
+        <>
+            <BoardHeader icon={<Award className="h-5 w-5" />} title="Weekly Contest" subtitle={contestName ? `Latest: ${contestName} (your class)` : "Latest finished contest"} />
+            {!hasContest ? <EmptyState message="No completed contests yet." /> : loading ? <ChartSkeleton height={300} /> : rows.length ? <DataTable columns={cols} rows={rows} searchable searchKeys={r => r.user_name} searchPlaceholder="Search participants…" pageSize={15} /> : <UnavailablePill reason="Contest ranking is class-scoped and returned no rows for the latest contest." />}
+        </>
+    );
+}
+
+function ImprovedBoard({ rows, loading, contestName, hasContest }: { rows: { user_name: string; rating_delta: number; rating_after: number }[]; loading: boolean; contestName?: string; hasContest: boolean }) {
+    const sorted = useMemo(() => [...rows].filter(r => r.rating_delta !== 0).sort((a, b) => b.rating_delta - a.rating_delta), [rows]);
+    const cols: Column<(typeof sorted)[number]>[] = [
+        { key: "rank", header: "#", render: (_r, i) => <RankBadge rank={i + 1} />, align: "center", className: "w-10" },
+        { key: "name", header: "Student", render: r => <NameCell name={r.user_name} /> },
+        { key: "after", header: "New Rating", render: r => <span className="text-muted-foreground tabular-nums">{(r.rating_after ?? 0).toLocaleString()}</span>, align: "right" },
+        { key: "delta", header: "Gain", render: r => <span className={`font-bold tabular-nums ${r.rating_delta > 0 ? "text-brand-500" : "text-destructive"}`}>{r.rating_delta > 0 ? "+" : ""}{r.rating_delta}</span>, align: "right" },
+    ];
+    return (
+        <>
+            <BoardHeader icon={<TrendingUp className="h-5 w-5" />} title="Most Improved" subtitle={contestName ? `Rating gains from ${contestName}` : "Biggest rating gains"} />
+            {!hasContest ? <EmptyState message="No completed contests yet." /> : loading ? <ChartSkeleton height={300} /> : sorted.length ? <DataTable columns={cols} rows={sorted} searchable searchKeys={r => r.user_name} searchPlaceholder="Search students…" pageSize={15} /> : <UnavailablePill reason="No rating changes available (contest ranking is class-scoped)." />}
+        </>
+    );
+}
