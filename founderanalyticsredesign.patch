@@ -0,0 +1,67 @@
+"use client";
+
+import { useMemo } from "react";
+import { BellRing, MousePointerClick, MailOpen, PlayCircle, Timer, Clock } from "lucide-react";
+import { hourDistribution } from "@/lib/api/analytics";
+import { useUsers } from "@/components/analytics/data";
+import { KpiCard, Card, Section, EmptyState, ChartSkeleton, PageHeading, UnavailablePill, LazyMount } from "@/components/analytics/primitives";
+import { BarChart } from "@/components/analytics/charts";
+
+export default function EngagementPage() {
+    const { users, loading } = useUsers();
+    const students = useMemo(() => users.filter(u => u.role === "STUDENT"), [users]);
+    const signupHours = useMemo(() => hourDistribution(students).map((count, h) => ({ label: `${h}`, count })), [students]);
+    const peakHour = useMemo(() => {
+        if (!students.length) return null;
+        let best = 0;
+        signupHours.forEach((h, i) => { if (h.count > signupHours[best].count) best = i; });
+        return best;
+    }, [signupHours, students.length]);
+
+    return (
+        <>
+            <PageHeading title="Engagement & Notifications" description="Delivery and session telemetry — mostly outside the current API surface." />
+
+            <div className="glass-card p-4 flex items-start gap-3">
+                <BellRing className="h-5 w-5 text-brand-500 shrink-0 mt-0.5" />
+                <p className="text-sm text-muted-foreground">
+                    The notifications API can <span className="text-foreground font-medium">send</span> broadcasts, but exposes no
+                    delivery, open, or click telemetry, and there is no session/heartbeat endpoint. Those metrics are marked
+                    <span className="text-foreground font-medium"> Data Not Available</span> rather than estimated. The one honest
+                    signal we can derive — new-user sign-up timing — is shown below.
+                </p>
+            </div>
+
+            <div className="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-4">
+                <KpiCard label="Notification Opens" value="—" icon={<MailOpen className="h-5 w-5" />} unavailable unavailableReason="No delivery/open telemetry is exposed by the notifications API." />
+                <KpiCard label="Click-through Rate" value="—" icon={<MousePointerClick className="h-5 w-5" />} accent="blue" unavailable unavailableReason="No click tracking on notifications." />
+                <KpiCard label="Session Starts" value="—" icon={<PlayCircle className="h-5 w-5" />} accent="purple" unavailable unavailableReason="No session/analytics events endpoint exists." />
+                <KpiCard label="Avg Session Duration" value="—" icon={<Timer className="h-5 w-5" />} accent="pink" unavailable unavailableReason="No session heartbeat is recorded server-side." />
+                <KpiCard label="Solved After Notification" value="—" icon={<BellRing className="h-5 w-5" />} unavailable unavailableReason="Requires attributing solves to a notification — no such linkage is exposed." />
+                <KpiCard label="Peak Sign-up Hour" value={peakHour !== null ? `${String(peakHour).padStart(2, "0")}:00` : "—"} icon={<Clock className="h-5 w-5" />} accent="blue" sub="IST · registrations" unavailable={students.length === 0} unavailableReason="No registration data." />
+            </div>
+
+            <LazyMount>
+                <Section title="Sign-up Activity" description="When new students register, in IST (a proxy for reachable hours)">
+                    <Card title="New Registrations by Hour of Day">
+                        {loading ? <ChartSkeleton height={220} /> : students.length ? <BarChart data={signupHours} height={220} labelEvery={2} /> : <EmptyState message="No registration data." />}
+                    </Card>
+                </Section>
+            </LazyMount>
+
+            <LazyMount>
+                <Section title="Notification & Session Metrics" description="Not derivable from the current backend">
+                    <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
+                        {[
+                            { t: "Notification Performance", r: "Broadcasts are fire-and-forget; no per-notification delivery/read stats are returned to admins." },
+                            { t: "Peak Usage Hours", r: "Requires session or per-attempt activity events, which are user-scoped and not exposed admin-wide." },
+                            { t: "Engagement Funnel", r: "No event pipeline (open → session → solve) is exposed to reconstruct a funnel." },
+                        ].map(x => (
+                            <Card key={x.t} title={x.t}><UnavailablePill reason={x.r} /></Card>
+                        ))}
+                    </div>
+                </Section>
+            </LazyMount>
+        </>
+    );
+}
