@@ -0,0 +1,108 @@
+"use client";
+
+import { useMemo, useState } from "react";
+import { Sun, CalendarRange, CalendarDays, UserPlus, Users as UsersIcon, Repeat } from "lucide-react";
+import {
+    registrationSeries,
+    hourDistribution,
+    weekdayDistribution,
+    istParts,
+} from "@/lib/api/analytics";
+import { useArena, useUsers } from "@/components/analytics/data";
+import { matchUser, type Filters } from "@/components/analytics/filters";
+import { RangeFilter, defaultRange, rangeLabel, type Range } from "@/components/analytics/range";
+import { KpiCard, Card, Section, EmptyState, ChartSkeleton, PageHeading, UnavailablePill, LazyMount } from "@/components/analytics/primitives";
+import { AreaChart, BarChart, Heatmap } from "@/components/analytics/charts";
+
+const WD = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
+
+export default function UsersAnalyticsPage() {
+    const [range, setRange] = useState<Range>(defaultRange);
+    const { users, loading } = useUsers();
+    const { rows: daily } = useArena("daily");
+    const { rows: weekly } = useArena("weekly");
+
+    const students = useMemo(() => users.filter(u => u.role === "STUDENT"), [users]);
+    const inRange = useMemo(() => {
+        const filters: Filters = { from: range.from, to: range.to, examType: "", classId: "", batch: "" };
+        return students.filter(u => matchUser(u, filters));
+    }, [students, range.from, range.to]);
+
+    const fullSeries = useMemo(() => registrationSeries(students), [students]);
+    const rangeSeries = useMemo(() => registrationSeries(inRange), [inRange]);
+
+    const dau = daily.length;
+    const wau = weekly.length;
+    const newInRange = inRange.length;
+
+    const hours = useMemo(() => hourDistribution(inRange).map((count, h) => ({ label: `${h}`, count })), [inRange]);
+    const weekdays = useMemo(() => weekdayDistribution(inRange), [inRange]);
+    const heat = useMemo(() => {
+        const g = Array.from({ length: 7 }, () => new Array(24).fill(0));
+        for (const u of inRange) {
+            const p = istParts(u.created_at);
+            if (p) g[p.weekdayIndex][p.hour] += 1;
+        }
+        return g;
+    }, [inRange]);
+
+    return (
+        <>
+            <PageHeading title="User Analytics" description="Acquisition, activity and growth of the student base." right={<RangeFilter value={range} onChange={setRange} />} />
+
+            <div className="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-4">
+                <KpiCard label="Total Students" value={students.length} icon={<UsersIcon className="h-5 w-5" />} sub="registered" />
+                <KpiCard label={`New (${rangeLabel(range)})`} value={newInRange} icon={<UserPlus className="h-5 w-5" />} accent="blue" sub="registrations in range" />
+                <KpiCard label="DAU" value={dau} icon={<Sun className="h-5 w-5" />} accent="purple" sub={dau >= 100 ? "top 100 (capped)" : "active today"} unavailable={daily.length === 0} unavailableReason="No arena activity today." />
+                <KpiCard label="WAU" value={wau} icon={<CalendarRange className="h-5 w-5" />} sub={wau >= 100 ? "top 100 (capped)" : "active this week"} unavailable={weekly.length === 0} unavailableReason="No weekly arena activity." />
+                <KpiCard label="MAU" value="—" icon={<CalendarDays className="h-5 w-5" />} unavailable unavailableReason="No monthly active window is exposed by the arena API." />
+                <KpiCard label="Returning Users" value="—" icon={<Repeat className="h-5 w-5" />} accent="pink" unavailable unavailableReason="Requires per-user session history, which no endpoint exposes." />
+            </div>
+
+            <LazyMount>
+                <Section title="Growth" description="Registrations over time (IST)">
+                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
+                        <Card title="Cumulative Students" subtitle={fullSeries.length ? `${fullSeries[0].date} → ${fullSeries.at(-1)!.date}` : undefined}>
+                            {loading ? <ChartSkeleton height={220} /> : fullSeries.length >= 2 ? <AreaChart points={fullSeries.map(p => p.cumulative)} labels={fullSeries.map(p => p.date.slice(5))} height={220} /> : <EmptyState message="Not enough history." />}
+                        </Card>
+                        <Card title={`New Registrations · ${rangeLabel(range)}`}>
+                            {loading ? <ChartSkeleton height={220} /> : rangeSeries.length >= 1 ? <BarChart data={rangeSeries.map(p => ({ label: p.date.slice(5), count: p.count }))} height={220} labelEvery={Math.max(1, Math.ceil(rangeSeries.length / 12))} color="var(--color-accent-blue)" /> : <EmptyState message="No registrations in this range." />}
+                        </Card>
+                    </div>
+                </Section>
+            </LazyMount>
+
+            <LazyMount>
+                <Section title="Activity Timeline" description="When students register, in IST">
+                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
+                        <Card title="By Hour of Day">
+                            {loading ? <ChartSkeleton /> : inRange.length ? <BarChart data={hours} labelEvery={3} /> : <EmptyState message="No data in range." />}
+                        </Card>
+                        <Card title="By Weekday">
+                            {loading ? <ChartSkeleton /> : inRange.length ? <BarChart data={weekdays} color="var(--color-accent-purple)" /> : <EmptyState message="No data in range." />}
+                        </Card>
+                        <Card title="Weekday × Hour Heatmap" className="lg:col-span-2">
+                            {loading ? <ChartSkeleton /> : inRange.length ? <Heatmap grid={heat} rows={WD} cols={Array.from({ length: 24 }, (_, h) => `${h}`)} /> : <EmptyState message="No data in range." />}
+                        </Card>
+                    </div>
+                </Section>
+            </LazyMount>
+
+            <LazyMount>
+                <Section title="Retention" description="Requires event data the API doesn't expose">
+                    <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
+                        {[
+                            { t: "User Retention (D1/D7/D30)", r: "No per-user event timeline is exposed; cohort return-rates can't be reconstructed from ranking snapshots." },
+                            { t: "Active vs Dormant", r: "Requires longitudinal per-user activity, which no available endpoint provides." },
+                            { t: "Churn Rate", r: "Depends on retention data that isn't derivable from the current API surface." },
+                        ].map(x => (
+                            <Card key={x.t} title={x.t}>
+                                <UnavailablePill reason={x.r} />
+                            </Card>
+                        ))}
+                    </div>
+                </Section>
+            </LazyMount>
+        </>
+    );
+}
