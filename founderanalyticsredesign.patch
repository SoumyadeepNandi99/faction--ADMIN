@@ -0,0 +1,96 @@
+"use client";
+
+import { useEffect, useMemo } from "react";
+import { Flame, Users, TrendingUp, Trophy, Gauge } from "lucide-react";
+import { bucketize, mean, median, saveSnapshot, snapshotDelta, snapshotSeries } from "@/lib/api/analytics";
+import { useStreak } from "@/components/analytics/data";
+import { KpiCard, Card, Section, EmptyState, ChartSkeleton, PageHeading, UnavailablePill, LazyMount, DataTable, RankBadge, NameCell, type Column } from "@/components/analytics/primitives";
+import { HBarList } from "@/components/analytics/charts";
+
+export default function StreaksAnalyticsPage() {
+    const { rows, loading } = useStreak();
+    const counts = rows.map(r => r.streak_count);
+    const active = rows.filter(r => r.streak_count > 0).length;
+    const avg = counts.length ? Math.round(mean(counts)) : 0;
+    const longest = counts.length ? Math.max(...counts) : 0;
+
+    useEffect(() => {
+        if (loading) return;
+        saveSnapshot({ activeStreaks: active, avgStreak: avg, longestStreak: longest });
+    }, [loading, active, avg, longest]);
+
+    const dist = useMemo(
+        () =>
+            bucketize(counts, [
+                { label: "1–2 days", min: 1, max: 2 },
+                { label: "3–6 days", min: 3, max: 6 },
+                { label: "1–2 weeks", min: 7, max: 14 },
+                { label: "2–4 weeks", min: 15, max: 30 },
+                { label: "1–3 months", min: 31, max: 90 },
+                { label: "3 months+", min: 91 },
+            ]),
+        [counts],
+    );
+
+    const cols: Column<(typeof rows)[number]>[] = [
+        { key: "rank", header: "#", render: (_r, i) => <RankBadge rank={i + 1} />, align: "center", className: "w-10" },
+        { key: "name", header: "Student", render: r => <NameCell name={r.user_name} /> },
+        { key: "streak", header: "Streak", render: r => <span className="font-bold tabular-nums">{(r.streak_count ?? 0).toLocaleString()} days</span>, align: "right" },
+    ];
+
+    return (
+        <>
+            <PageHeading title="Streak Analytics" description="Daily-habit consistency across the student base." />
+
+            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
+                <KpiCard label="Active Streak Holders" value={active} icon={<Flame className="h-5 w-5" />} sub="students on a streak" delta={snapshotDelta("activeStreaks", active)} spark={snapshotSeries("activeStreaks")} unavailable={rows.length === 0} unavailableReason="Streak ranking returned no rows." />
+                <KpiCard label="Average Streak" value={avg} icon={<Gauge className="h-5 w-5" />} accent="blue" sub="days" delta={snapshotDelta("avgStreak", avg)} spark={snapshotSeries("avgStreak")} />
+                <KpiCard label="Longest Streak" value={longest} icon={<Trophy className="h-5 w-5" />} accent="pink" sub="days" delta={snapshotDelta("longestStreak", longest)} />
+                <KpiCard label="Median Streak" value={counts.length ? Math.round(median(counts)) : "—"} icon={<Users className="h-5 w-5" />} accent="purple" sub="days" />
+            </div>
+
+            <LazyMount>
+                <Section title="Distribution & Leaders">
+                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
+                        <Card title="Streak Distribution">
+                            {loading ? <ChartSkeleton /> : rows.length ? <HBarList data={dist} colorByIndex /> : <EmptyState message="Streak ranking returned no rows." />}
+                        </Card>
+                        <Card title="Longest Streaks">
+                            {loading ? <ChartSkeleton /> : rows.length ? <DataTable columns={cols} rows={rows} pageSize={8} searchable searchKeys={r => r.user_name} searchPlaceholder="Search students…" /> : <EmptyState message="Streak ranking returned no rows." />}
+                        </Card>
+                    </div>
+                </Section>
+            </LazyMount>
+
+            <LazyMount>
+                <Section title="Trends & Risk" description="Growth builds from daily snapshots; risk needs last-activity data">
+                    <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
+                        <Card title="Streak Growth">
+                            {snapshotSeries("activeStreaks").length >= 2 ? (
+                                <div className="flex flex-col gap-2">
+                                    <p className="text-sm text-muted-foreground">Active streak holders, day over day.</p>
+                                    <HBarList data={snapshotSeries("activeStreaks").slice(-7).map((v, i) => ({ label: `Day ${i + 1}`, count: v }))} />
+                                </div>
+                            ) : (
+                                <UnavailablePill reason="Trend builds over time — snapshots accrue one point per day." />
+                            )}
+                        </Card>
+                        <Card title="Daily Streak Changes">
+                            <div className="flex items-center gap-2 text-sm">
+                                <TrendingUp className="h-4 w-4 text-brand-500" />
+                                {snapshotDelta("activeStreaks", active).available ? (
+                                    <span className="text-foreground font-medium">{snapshotDelta("activeStreaks", active).value >= 0 ? "+" : ""}{snapshotDelta("activeStreaks", active).value} active vs prev day</span>
+                                ) : (
+                                    <span className="text-muted-foreground">Builds after a day of history.</span>
+                                )}
+                            </div>
+                        </Card>
+                        <Card title="Close to Losing Streak">
+                            <UnavailablePill reason="The streak ranking doesn't expose each student's last-activity date, so at-risk streaks can't be identified." />
+                        </Card>
+                    </div>
+                </Section>
+            </LazyMount>
+        </>
+    );
+}
