+"use client";
+
+import { useMemo, useState } from "react";
+import { CalendarClock, ListChecks, Users, Percent, Timer } from "lucide-react";
+import { istTodayKey } from "@/lib/api/analytics";
+import { useClasses, useQotdEligible, useQotdHistory, useQotdSchedule } from "@/components/analytics/data";
+import { RangeFilter, defaultRange, rangeLabel, type Range } from "@/components/analytics/range";
+import { KpiCard, Card, Section, EmptyState, ChartSkeleton, PageHeading, UnavailablePill, LazyMount } from "@/components/analytics/primitives";
+import { BarChart } from "@/components/analytics/charts";
+import { CustomSelect } from "@/components/ui/custom-select";
+import { EXAM_TYPE_OPTIONS } from "@/lib/exam-types";
+
+export default function PotdAnalyticsPage() {
+    const [range, setRange] = useState<Range>(defaultRange);
+    const { classes } = useClasses();
+    const [classSel, setClassSel] = useState("");
+    const [examSel, setExamSel] = useState("");
+
+    // Default the selectors (latest class / first exam) via derived values rather
+    // than syncing state through an effect.
+    const classId = classSel || (classes[0]?.id ?? "");
+    const exam = examSel || EXAM_TYPE_OPTIONS[0].value;
+
+    const today = istTodayKey();
+    const { schedule: todaySchedule, loading: todayLoading } = useQotdSchedule(today, classId, exam);
+    const { total: eligible, loading: eligibleLoading } = useQotdEligible(exam);
+    const { history, loading: histLoading } = useQotdHistory(classId, exam, range.from, range.to);
+
+    const scheduledDays = history.filter(h => h.scheduled).length;
+    const coverage = history.length ? Math.round((scheduledDays / history.length) * 100) : 0;
+    const histBars = useMemo(() => history.map(h => ({ label: h.date.slice(5), count: h.questionCount })), [history]);
+
+    const classOptions = [{ label: "Select class", value: "" }, ...classes.map(c => ({ label: c.name, value: c.id }))];
+    const ready = classId && exam;
+
+    return (
+        <>
+            <PageHeading title="POTD Analytics" description="Problem of the Day — scheduling coverage and participation." right={<RangeFilter value={range} onChange={setRange} />} />
+
+            <div className="glass-card p-4 flex flex-wrap items-end gap-3">
+                <div className="flex flex-col gap-1">
+                    <span className="text-xs text-muted-foreground">Class</span>
+                    <div className="w-44"><CustomSelect value={classId} onChange={setClassSel} options={classOptions} placeholder="Select class" /></div>
+                </div>
+                <div className="flex flex-col gap-1">
+                    <span className="text-xs text-muted-foreground">Exam</span>
+                    <div className="w-44"><CustomSelect value={exam} onChange={setExamSel} options={EXAM_TYPE_OPTIONS} placeholder="Select exam" /></div>
+                </div>
+                <p className="text-xs text-muted-foreground ml-auto max-w-md">POTD schedules are keyed by class + exam, so pick a cohort to inspect. Per-student POTD attempts aren&apos;t exposed admin-wide.</p>
+            </div>
+
+            <div className="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-4">
+                <KpiCard label="Scheduled Today" value={ready ? (todaySchedule?.question_ids.length ?? 0) : "—"} icon={<ListChecks className="h-5 w-5" />} sub={ready ? (todaySchedule?.id ? "questions set" : "none scheduled") : "select a cohort"} unavailable={ready ? !todayLoading && !todaySchedule?.id : true} unavailableReason={ready ? "No POTD scheduled for today." : "Pick a class + exam above."} />
+                <KpiCard label={`Coverage · ${rangeLabel(range)}`} value={ready ? `${coverage}%` : "—"} icon={<Percent className="h-5 w-5" />} accent="blue" sub={ready ? `${scheduledDays}/${history.length} days scheduled` : undefined} unavailable={!ready} unavailableReason="Pick a class + exam above." />
+                <KpiCard label="Eligible Pool" value={ready ? eligible : "—"} icon={<CalendarClock className="h-5 w-5" />} accent="purple" sub="POTD-eligible questions" unavailable={ready ? !eligibleLoading && eligible === 0 : true} unavailableReason={ready ? "No eligible questions for this exam." : "Pick a class + exam above."} />
+                <KpiCard label="Today's Solvers" value="—" icon={<Users className="h-5 w-5" />} unavailable unavailableReason="Per-student POTD attempts aren't exposed to admins." />
+                <KpiCard label="Participation Rate" value="—" icon={<Percent className="h-5 w-5" />} accent="pink" unavailable unavailableReason="Needs solver counts, which aren't derivable admin-wide." />
+                <KpiCard label="Avg Solving Time" value="—" icon={<Timer className="h-5 w-5" />} unavailable unavailableReason="No per-attempt timing endpoint exists." />
+            </div>
+
+            <LazyMount>
+                <Section title="Scheduling History" description="POTD questions scheduled per day for the selected cohort">
+                    <Card title={`Questions Scheduled · ${rangeLabel(range)}`}>
+                        {!ready ? (
+                            <EmptyState message="Select a class and exam to see POTD scheduling history." />
+                        ) : histLoading ? (
+                            <ChartSkeleton height={220} />
+                        ) : histBars.some(b => b.count > 0) ? (
+                            <BarChart data={histBars} height={220} labelEvery={Math.max(1, Math.ceil(histBars.length / 12))} color="var(--color-brand-500)" />
+                        ) : (
+                            <EmptyState message="No POTD scheduled in this range for the selected cohort." />
+                        )}
+                    </Card>
+                </Section>
+            </LazyMount>
+
+            <LazyMount>
+                <Section title="Participation & Consistency" description="Not derivable — POTD attempts are user-scoped">
+                    <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
+                        {[
+                            { t: "Correct vs Incorrect", r: "Per-attempt correctness isn't exposed admin-wide." },
+                            { t: "Solve Timeline (hourly)", r: "No admin-wide per-attempt timestamps to bucket by hour." },
+                            { t: "Most Consistent Solvers", r: "Requires per-student POTD solve history, which isn't exposed." },
+                            { t: "POTD Streak Analytics", r: "The streak endpoint tracks overall study streaks, not POTD-specific streaks." },
+                        ].map(x => (
+                            <Card key={x.t} title={x.t}><UnavailablePill reason={x.r} /></Card>
+                        ))}
+                    </div>
+                </Section>
+            </LazyMount>
+        </>
+    );
+}
