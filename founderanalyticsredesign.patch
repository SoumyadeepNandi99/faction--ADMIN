+export async function fetchQotdHistory(
+    class_id: string,
+    exam_type: string,
+    from: string,
+    to: string,
+    maxDays = 60,
+): Promise<QotdHistoryDay[]> {
+    if (!class_id || !exam_type || !from || !to) return [];
