+// ---------------------------------------------------------------------------
+// Question-bank stats — the /questions/ list endpoint reports a `total` for any
+// filter combination, so we can derive bank composition (difficulty / exam)
+// with cheap count-only queries (limit=1) instead of paging the whole bank.
+// NOTE: these describe the QUESTION BANK, not what students have solved — the
+// per-attempt solve feed is user-scoped and not derivable admin-wide.
+// ---------------------------------------------------------------------------
+
+export async function fetchQuestionTotal(params: Record<string, string | number | boolean> = {}): Promise<number> {
+    try {
+        const { data } = await apiClient.get("/api/v1/questions/", { params: { ...params, limit: 1 } });
+        return num((data as { total?: unknown; questions?: unknown[] })?.total, (data as { questions?: unknown[] })?.questions?.length);
+    } catch {
+        return 0;
+    }
+}
+
+const DIFFICULTIES = [
+    { label: "Easy", value: 1 },
+    { label: "Medium", value: 2 },
+    { label: "Hard", value: 3 },
+];
+
+/** Bank difficulty split (optionally within one exam track). */
+export async function fetchDifficultyDistribution(exam_type?: string): Promise<Bucket[]> {
+    const counts = await Promise.all(
+        DIFFICULTIES.map(d => fetchQuestionTotal({ difficulty: d.value, ...(exam_type ? { exam_type } : {}) })),
+    );
+    return DIFFICULTIES.map((d, i) => ({ label: d.label, count: counts[i] }));
+}
+
+const BANK_EXAMS = ["JEE_MAINS", "JEE_ADVANCED", "NEET", "OLYMPIAD", "CBSE"];
+
+/** Bank size per exam track. */
+export async function fetchBankExamDistribution(): Promise<Bucket[]> {
+    const counts = await Promise.all(BANK_EXAMS.map(e => fetchQuestionTotal({ exam_type: e })));
+    return BANK_EXAMS.map((e, i) => ({ label: e, count: counts[i] })).filter(b => b.count > 0);
+}
