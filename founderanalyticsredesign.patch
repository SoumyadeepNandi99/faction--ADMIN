+++ b/src/app/(dashboard)/analytics/contests/page.tsx
@@ -0,0 +1,153 @@
+"use client";
+
+import { useMemo, useState } from "react";
+import useSWR from "swr";
+import { Award, Users, Star, TrendingUp, Trophy, Medal } from "lucide-react";
+import { bucketize, fetchContestRanking, mean, median, istParts, type ContestRow } from "@/lib/api/analytics";
+import { useContests } from "@/components/analytics/data";
+import { RangeFilter, defaultRange, type Range } from "@/components/analytics/range";
+import { KpiCard, Card, Section, EmptyState, ChartSkeleton, PageHeading, UnavailablePill, LazyMount, DataTable, RankBadge, NameCell, type Column } from "@/components/analytics/primitives";
+import { HBarList, BarChart } from "@/components/analytics/charts";
+import { CustomSelect } from "@/components/ui/custom-select";
+import { formatDate } from "@/lib/datetime";
+
+function monthKey(c: ContestRow): string | null {
+    const p = istParts(c.starts_at || c.created_at);
+    return p ? p.dateKey.slice(0, 7) : null;
+}
+
+export default function ContestsAnalyticsPage() {
+    const [range, setRange] = useState<Range>(defaultRange);
+    const { contests, loading } = useContests();
+
+    const finished = useMemo(
+        () => [...contests].filter(c => c.status === "finished").sort((a, b) => new Date(b.starts_at).getTime() - new Date(a.starts_at).getTime()),
+        [contests],
+    );
+    const upcoming = contests.filter(c => c.status !== "finished");
+
+    const [selected, setSelected] = useState("");
+    // Derive the effective selection (default to the latest finished contest)
+    // instead of syncing via an effect.
+    const effSelected = selected || (finished[0]?.id ?? "");
+
+    const { data: ranking, isLoading: rankingLoading } = useSWR(
+        effSelected ? `analytics:contest-ranking:${effSelected}` : null,
+        () => fetchContestRanking(effSelected),
+        { revalidateOnFocus: false, dedupingInterval: 300_000 },
+    );
+    const rows = ranking?.rows ?? [];
+    const scores = rows.map(r => r.score);
+
+    // Participation trend across the most recent finished contests (bounded).
+    const trendContests = useMemo(() => finished.slice(0, 10).reverse(), [finished]);
+    const { data: trend } = useSWR(
+        trendContests.length ? `analytics:contest-trend:${trendContests.map(c => c.id).join(",")}` : null,
+        async () => {
+            const totals = await Promise.all(trendContests.map(c => fetchContestRanking(c.id).then(r => r.total).catch(() => 0)));
+            return trendContests.map((c, i) => ({ label: c.name.slice(0, 12), count: totals[i] }));
+        },
+        { revalidateOnFocus: false, dedupingInterval: 300_000 },
+    );
+
+    const byMonth = useMemo(() => {
+        const m = new Map<string, number>();
+        for (const c of contests) {
+            const k = monthKey(c);
+            if (k) m.set(k, (m.get(k) ?? 0) + 1);
+        }
+        return [...m.entries()].sort(([a], [b]) => a.localeCompare(b)).map(([label, count]) => ({ label: label.slice(2), count }));
+    }, [contests]);
+
+    const scoreDist = useMemo(() => {
+        if (!scores.length) return [];
+        const max = Math.max(...scores, 1);
+        const step = Math.max(1, Math.ceil(max / 6));
+        const edges = Array.from({ length: 6 }, (_, i) => ({ label: `${i * step}–${(i + 1) * step}`, min: i * step, max: (i + 1) * step }));
+        return bucketize(scores, edges);
+    }, [scores]);
+
+    const rankCols: Column<(typeof rows)[number]>[] = [
+        { key: "rank", header: "#", render: r => <RankBadge rank={r.rank} />, align: "center", className: "w-10" },
+        { key: "name", header: "Student", render: r => <NameCell name={r.user_name} /> },
+        { key: "acc", header: "Accuracy", render: r => <span className="text-muted-foreground tabular-nums">{Math.round((r.accuracy || 0) * 100)}%</span>, align: "right" },
+        { key: "delta", header: "Rating Δ", render: r => <span className={`tabular-nums font-medium ${r.rating_delta > 0 ? "text-brand-500" : r.rating_delta < 0 ? "text-destructive" : "text-muted-foreground"}`}>{r.rating_delta > 0 ? "+" : ""}{r.rating_delta || 0}</span>, align: "right" },
+        { key: "score", header: "Score", render: r => <span className="font-bold tabular-nums">{(r.score ?? 0).toLocaleString()}</span>, align: "right" },
+    ];
+
+    const histCols: Column<ContestRow>[] = [
+        { key: "name", header: "Contest", render: c => <span className="font-medium truncate">{c.name}</span> },
+        { key: "exam", header: "Exam", render: c => <span className="text-xs text-muted-foreground">{c.exam_type}</span> },
+        { key: "date", header: "Starts", render: c => <span className="text-xs text-muted-foreground">{formatDate(c.starts_at)}</span>, align: "right" },
+        { key: "status", header: "Status", render: c => <span className={`text-xs font-medium ${c.status === "finished" ? "text-muted-foreground" : "text-brand-500"}`}>{c.status.replace("_", " ")}</span>, align: "right" },
+    ];
+
+    const selectedContest = finished.find(c => c.id === effSelected);
+
+    return (
+        <>
+            <PageHeading title="Weekly Contest Analytics" description="Assessment cadence, scores and participation." right={<RangeFilter value={range} onChange={setRange} />} />
+
+            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
+                <KpiCard label="Total Contests" value={loading ? "…" : contests.length} icon={<Award className="h-5 w-5" />} />
+                <KpiCard label="Completed" value={loading ? "…" : finished.length} icon={<Trophy className="h-5 w-5" />} accent="blue" />
+                <KpiCard label="Upcoming" value={loading ? "…" : upcoming.length} icon={<TrendingUp className="h-5 w-5" />} accent="purple" />
+                <KpiCard label="This Month" value={loading ? "…" : (byMonth.at(-1)?.count ?? 0)} icon={<Award className="h-5 w-5" />} accent="pink" sub="scheduled" />
+            </div>
+
+            <div className="glass-card p-4 flex flex-wrap items-end gap-3">
+                <div className="flex flex-col gap-1">
+                    <span className="text-xs text-muted-foreground">Inspect contest</span>
+                    <div className="w-72"><CustomSelect value={effSelected} onChange={setSelected} options={finished.length ? finished.map(c => ({ label: c.name, value: c.id })) : [{ label: "No completed contests", value: "" }]} placeholder="Select a contest" /></div>
+                </div>
+                <p className="text-xs text-muted-foreground ml-auto max-w-md">Contest rankings are scoped to your class by the backend, so per-contest detail reflects your own cohort.</p>
+            </div>
+
+            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
+                <KpiCard label="Participants" value={ranking?.total ?? 0} icon={<Users className="h-5 w-5" />} sub={selectedContest?.name} unavailable={!effSelected || (ranking?.total ?? 0) === 0} unavailableReason="No ranking rows for this contest in your class." />
+                <KpiCard label="Average Score" value={scores.length ? Math.round(mean(scores)) : "—"} icon={<Star className="h-5 w-5" />} accent="blue" />
+                <KpiCard label="Median Score" value={scores.length ? Math.round(median(scores)) : "—"} icon={<Medal className="h-5 w-5" />} accent="purple" />
+                <KpiCard label="Highest Score" value={scores.length ? Math.max(...scores) : "—"} icon={<Trophy className="h-5 w-5" />} accent="pink" />
+            </div>
+
+            <LazyMount>
+                <Section title="Cadence & Participation">
+                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
+                        <Card title="Contests / Month">
+                            {loading ? <ChartSkeleton /> : byMonth.length ? <BarChart data={byMonth} color="var(--color-accent-purple)" /> : <EmptyState message="No contests scheduled yet." />}
+                        </Card>
+                        <Card title="Participation Trend" subtitle="Participants per recent contest (your class)">
+                            {loading ? <ChartSkeleton /> : trend && trend.some(t => t.count > 0) ? <BarChart data={trend} labelEvery={Math.max(1, Math.ceil(trend.length / 8))} /> : <UnavailablePill reason="Contest ranking is class-scoped and returned no participants for recent contests." />}
+                        </Card>
+                    </div>
+                </Section>
+            </LazyMount>
+
+            <LazyMount>
+                <Section title={selectedContest ? `Detail · ${selectedContest.name}` : "Contest Detail"}>
+                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
+                        <Card title="Score Distribution">
+                            {rankingLoading ? <ChartSkeleton /> : scoreDist.length ? <HBarList data={scoreDist} colorByIndex /> : <EmptyState message="No participant scores for this contest." />}
+                        </Card>
+                        <Card title="Leaderboard">
+                            {rankingLoading ? <ChartSkeleton /> : rows.length ? <DataTable columns={rankCols} rows={rows} pageSize={8} searchable searchKeys={r => r.user_name} searchPlaceholder="Search participants…" /> : <UnavailablePill reason="No ranking rows — this contest is outside your class or had no participants." />}
+                        </Card>
+                    </div>
+                </Section>
+            </LazyMount>
+
+            <LazyMount>
+                <Section title="Contest History">
+                    <Card>
+                        {loading ? <ChartSkeleton height={260} /> : contests.length ? <DataTable columns={histCols} rows={[...contests].sort((a, b) => new Date(b.starts_at).getTime() - new Date(a.starts_at).getTime())} pageSize={10} searchable searchKeys={c => c.name} searchPlaceholder="Search contests…" /> : <EmptyState message="No contests found." />}
+                    </Card>
+                </Section>
+            </LazyMount>
+
+            <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
+                <Card title="Completion Rate"><UnavailablePill reason="The ranking exposes attempts & correctness but not per-student start-vs-finish, so a true completion rate isn't derivable." /></Card>
+                <Card title="Leaderboard Changes"><UnavailablePill reason="Requires historical rank snapshots across contests, which aren't stored/exposed." /></Card>
+            </div>
+        </>
+    );
+}
diff --git a/src/app/(dashboard)/analytics/engagement/page.tsx b/src/app/(dashboard)/analytics/engagement/page.tsx
